{
  "name": "tech-signal-telegram-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/src/index.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "x:login": "npm run build && node --env-file=.env dist/src/scripts/openXBrowser.js",
    "x:edge": "npm run build && node --env-file=.env dist/src/scripts/startSignedInEdge.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.7.3",
    "playwright": "^1.59.1"
  }
}
